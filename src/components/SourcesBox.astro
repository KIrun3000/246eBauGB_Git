---
export interface Source {
  label: string;
  url: string;
  type?: 'primary' | 'secondary';
}

export interface Props {
  sources?: Source[];
  primarySources?: Source[];
  secondarySources?: Source[];
}

const { sources, primarySources, secondarySources } = Astro.props;
const primary = primarySources || (sources ? sources.filter((source) => source.type === 'primary') : []);
const secondary = secondarySources || (sources ? sources.filter((source) => source.type === 'secondary') : []);
const uncategorized = sources ? sources.filter((source) => !source.type) : [];
---

{(primary.length > 0 || secondary.length > 0 || uncategorized.length > 0) && (
  <aside class="sources-box" aria-labelledby="sources-title">
    <header>
      <span aria-hidden="true">Q</span>
      <div>
        <p>Nachvollziehbar belegt</p>
        <h2 id="sources-title">Quellen & Vertiefung</h2>
      </div>
    </header>

    {primary.length > 0 && (
      <section class="source-category">
        <h3>Primärquellen</h3>
        <ul>
          {primary.map((source) => (
            <li>
              <a href={source.url} target="_blank" rel="noopener noreferrer">
                {source.label}
                <span class="sr-only"> (öffnet in neuem Tab)</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {secondary.length > 0 && (
      <section class="source-category">
        <h3>Weiterführende Quellen</h3>
        <ul>
          {secondary.map((source) => (
            <li>
              <a href={source.url} target="_blank" rel="noopener noreferrer">
                {source.label}
                <span class="sr-only"> (öffnet in neuem Tab)</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {uncategorized.length > 0 && (
      <section class="source-category">
        <h3>Verwendete Quellen</h3>
        <ul>
          {uncategorized.map((source) => (
            <li>
              <a href={source.url} target="_blank" rel="noopener noreferrer">
                {source.label}
                <span class="sr-only"> (öffnet in neuem Tab)</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </aside>
)}

<style>
  .sources-box {
    margin: 3rem 0 0;
    padding: clamp(1.4rem, 4vw, 2rem);
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }

  .sources-box > header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--line);
  }

  .sources-box > header > span {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    color: var(--white);
    background: var(--blue-900);
    border-radius: 50%;
    font-family: ui-monospace, "SFMono-Regular", Consolas, monospace;
    font-size: 0.8rem;
    font-weight: 900;
  }

  .sources-box header p {
    margin: 0 0 0.2rem;
    color: var(--brick-600);
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .sources-box h2 {
    margin: 0;
    font-size: 1.35rem;
  }

  .source-category {
    padding-top: 1.4rem;
  }

  .source-category h3 {
    margin: 0 0 0.75rem;
    color: var(--ink-600);
    font-family: "Avenir Next", Avenir, "Segoe UI", system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .source-category ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .source-category li {
    margin: 0;
    padding: 0.6rem 0 0.6rem 1.25rem;
    position: relative;
    border-top: 1px solid var(--line);
  }

  .source-category li::before {
    content: "↗";
    position: absolute;
    top: 0.62rem;
    left: 0;
    color: var(--brick-600);
    font-weight: 900;
  }

  .source-category a {
    color: var(--blue-800);
    font-size: 0.86rem;
    line-height: 1.45;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .source-category a:hover {
    color: var(--brick-600);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
