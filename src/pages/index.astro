---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE, absoluteSiteUrl } from '../lib/site';
import { getBlogVisual } from '../lib/blogVisuals';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = sortedPosts[0];
const featuredVisual = featuredPost ? getBlogVisual(featuredPost.data.image) : undefined;
const latestPosts = sortedPosts.slice(1, 5);
const dateFormatter = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const categoryLabels: Record<string, string> = {
  grundlagen: 'Grundlagen',
  '100m': '100-m-Leitplanke',
  aussenbereich: 'Außenbereich',
  ablauf: 'Verfahren',
  faq: 'Praxisfragen',
};
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  alternateName: SITE.shortName,
  url: SITE.url,
  inLanguage: 'de-DE',
  publisher: {
    '@type': 'Person',
    name: SITE.publisher.name,
    url: absoluteSiteUrl(SITE.publisher.page),
  },
};
---

<BaseLayout
  title="§ 246e BauGB Brandenburg – Orientierung für Grundstückseigentümer"
  description="§ 246e BauGB verständlich erklärt: Grundstück, 100-m-Leitplanke, Außenbereich und Gemeinde-Zustimmung für private Eigentümer in Brandenburg."
  structuredData={structuredData}
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="container hero__grid">
      <div class="hero__content">
        <p class="eyebrow">Bau-Turbo · Brandenburg · Private Eigentümer</p>
        <h1 id="hero-title">
          Bauen, wo es bisher <span>schwierig</span> war?
        </h1>
        <p class="hero__lead">
          § 246e BauGB eröffnet befristete Spielräume für neuen Wohnraum.
          Hier ordnen Sie Grundstück, räumlichen Zusammenhang und Verfahren
          verständlich ein – bevor Sie die nächsten Schritte planen.
        </p>
        <div class="hero__actions">
          <a href="/grundstueckspotenzial-brandenburg/" class="button button--primary">
            Grundstück einordnen
            <svg aria-hidden="true" viewBox="0 0 18 18">
              <path d="M3 9h11M9.5 3.5 15 9l-5.5 5.5" />
            </svg>
          </a>
          <a href="/246e-baugb-brandenburg/" class="button button--secondary">
            Regelung verstehen
          </a>
        </div>
        <ul class="hero__assurances" aria-label="Wichtige Einordnung">
          <li>
            <svg aria-hidden="true" viewBox="0 0 18 18">
              <path d="m4 9 3 3 7-7" />
            </svg>
            Ohne Juristendeutsch
          </li>
          <li>
            <svg aria-hidden="true" viewBox="0 0 18 18">
              <path d="m4 9 3 3 7-7" />
            </svg>
            Mit Primärquellen
          </li>
          <li>
            <svg aria-hidden="true" viewBox="0 0 18 18">
              <path d="m4 9 3 3 7-7" />
            </svg>
            Keine Rechtsberatung
          </li>
        </ul>
      </div>

      <figure class="parcel-plan">
        <div class="parcel-plan__head">
          <span>Schematische Vorprüfung</span>
          <span translate="no">BB · Flurstück 246e</span>
        </div>
        <svg
          class="parcel-plan__drawing"
          viewBox="0 0 560 410"
          role="img"
          aria-labelledby="parcel-title parcel-desc"
        >
          <title id="parcel-title">Schematischer Lageplan eines Grundstücks</title>
          <desc id="parcel-desc">
            Grundstücksgrenzen, vorhandene Bebauung und eine gestrichelte
            100-Meter-Leitplanke zur ersten Orientierung.
          </desc>
          <defs>
            <pattern id="parcel-grid" width="24" height="24" patternUnits="userSpaceOnUse">
              <path d="M24 0H0V24" fill="none" stroke="#9bb0ba" stroke-width="0.6" opacity="0.5" />
            </pattern>
            <pattern id="parcel-hatch" width="8" height="8" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
              <line x1="0" y1="0" x2="0" y2="8" stroke="#66806d" stroke-width="2" opacity="0.45" />
            </pattern>
          </defs>
          <rect width="560" height="410" fill="url(#parcel-grid)" />
          <path d="M-20 315 148 276 287 301 404 251 590 275" fill="none" stroke="#073b5c" stroke-width="18" opacity="0.11" />
          <path d="M35 62 218 30 253 178 78 212Z" fill="#fff" stroke="#073b5c" stroke-width="2" />
          <path d="M218 30 482 75 445 221 253 178Z" fill="url(#parcel-hatch)" stroke="#073b5c" stroke-width="2" />
          <path d="M78 212 253 178 287 301 118 346Z" fill="#dcecf1" stroke="#073b5c" stroke-width="2" />
          <path d="M253 178 445 221 404 350 287 301Z" fill="#fff" stroke="#073b5c" stroke-width="2" />
          <rect x="122" y="112" width="76" height="48" rx="2" fill="#073b5c" />
          <path d="m115 112 45-30 45 30" fill="#be4f37" stroke="#be4f37" stroke-width="8" stroke-linejoin="round" />
          <circle cx="160" cy="136" r="112" fill="none" stroke="#be4f37" stroke-width="2.5" stroke-dasharray="8 7" />
          <line x1="160" y1="136" x2="267" y2="102" stroke="#be4f37" stroke-width="2.5" />
          <circle cx="160" cy="136" r="6" fill="#be4f37" />
          <circle cx="267" cy="102" r="6" fill="#be4f37" />
          <g transform="translate(328 42)">
            <rect width="168" height="58" rx="4" fill="#073b5c" />
            <text x="16" y="24" fill="#fff" font-size="12" font-family="sans-serif" font-weight="700">100-m-Leitplanke</text>
            <text x="16" y="43" fill="#dcecf1" font-size="10" font-family="sans-serif">aus der Gesetzesbegründung</text>
          </g>
          <g transform="translate(315 310)">
            <line x1="0" y1="0" x2="92" y2="0" stroke="#073b5c" stroke-width="2" />
            <line x1="0" y1="-6" x2="0" y2="6" stroke="#073b5c" stroke-width="2" />
            <line x1="92" y1="-6" x2="92" y2="6" stroke="#073b5c" stroke-width="2" />
            <text x="29" y="-10" fill="#073b5c" font-size="11" font-family="sans-serif">100 m</text>
          </g>
          <text x="91" y="241" fill="#073b5c" font-size="11" font-family="sans-serif" font-weight="700">FLUR 03</text>
          <text x="315" y="247" fill="#073b5c" font-size="11" font-family="sans-serif" font-weight="700">FLUR 04</text>
        </svg>
        <figcaption>
          <span class="parcel-plan__legend">
            <i class="legend-dot legend-dot--brick"></i>
            Messbezug
          </span>
          <span class="parcel-plan__legend">
            <i class="legend-dot legend-dot--land"></i>
            möglicher Zusammenhang
          </span>
          <span>Keine amtliche Karte</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="facts" aria-label="Drei zentrale Voraussetzungen">
    <div class="container facts__grid">
      <article>
        <span class="facts__label">Zeitrahmen</span>
        <strong>Bis Ende 2030 befristet</strong>
        <a href="https://www.gesetze-im-internet.de/bbaug/__246e.html" target="_blank" rel="noopener noreferrer">
          § 246e Abs. 4 BauGB
        </a>
      </article>
      <article>
        <span class="facts__label">Gemeinde</span>
        <strong>Zustimmung erforderlich</strong>
        <a href="/zustimmung-gemeinde-246e/">Verfahren einordnen</a>
      </article>
      <article>
        <span class="facts__label">Außenbereich</span>
        <strong>Immer Einzelfallprüfung</strong>
        <a href="/100m-regel-raeumlicher-zusammenhang/">Leitplanke verstehen</a>
      </article>
    </div>
  </section>

  <section class="topics">
    <div class="container">
      <header class="section-head">
        <div>
          <p class="eyebrow">Einstieg nach Ihrer Frage</p>
          <h2>Was möchten Sie klären?</h2>
        </div>
        <p>
          Vier Themen führen von der ersten rechtlichen Einordnung bis zum
          Gespräch mit Gemeinde und Bauaufsicht.
        </p>
      </header>

      <div class="topics__grid">
        <a href="/246e-baugb-brandenburg/" class="topic-card topic-card--feature">
          <span class="topic-card__meta">Rechtslage · Überblick</span>
          <div>
            <h3>Was § 246e ermöglicht – und wo die Grenzen liegen</h3>
            <p>
              Voraussetzungen, Anwendungsfälle und Befristung kompakt erklärt.
            </p>
          </div>
          <span class="topic-card__link">
            Grundlagen lesen
            <svg aria-hidden="true" viewBox="0 0 18 18">
              <path d="M3 9h11M9.5 3.5 15 9l-5.5 5.5" />
            </svg>
          </span>
          <svg class="topic-card__plan" aria-hidden="true" viewBox="0 0 240 210">
            <path d="M-20 180 84 118l76 25 100-73" />
            <path d="M20 12 112 32 86 112 6 92ZM112 32l108 20-20 88-114-28Z" />
            <circle cx="84" cy="98" r="56" />
            <path d="M84 98h56" />
          </svg>
        </a>

        <a href="/100m-regel-raeumlicher-zusammenhang/" class="topic-card">
          <span class="topic-card__meta">Grundstück · Lage</span>
          <h3>100-m-Leitplanke & räumlicher Zusammenhang</h3>
          <p>
            Warum 100 Meter keine starre Regel sind und welche Kriterien zählen.
          </p>
          <span class="topic-card__link">Grundstück einordnen</span>
        </a>

        <a href="/aussenbereich-brandenburg-246e/" class="topic-card">
          <span class="topic-card__meta">Fachrecht · Brandenburg</span>
          <h3>Außenbereich, Natur & Erschließung</h3>
          <p>
            Welche Belange trotz planungsrechtlicher Erleichterung weiter gelten.
          </p>
          <span class="topic-card__link">Prüfpunkte ansehen</span>
        </a>

        <a href="/zustimmung-gemeinde-246e/" class="topic-card">
          <span class="topic-card__meta">Verfahren · Gemeinde</span>
          <h3>Vom Vorhaben zur Gemeinde-Zustimmung</h3>
          <p>
            Unterlagen vorbereiten, Rollen verstehen und sachlich ins Gespräch gehen.
          </p>
          <span class="topic-card__link">Ablauf verstehen</span>
        </a>
      </div>
    </div>
  </section>

  <section class="pathway">
    <div class="container">
      <header class="pathway__head">
        <p class="eyebrow eyebrow--light">Orientierung in vier Schritten</p>
        <h2>Vom Grundstück zur belastbaren Anfrage</h2>
      </header>
      <ol class="pathway__steps">
        <li>
          <span>01</span>
          <div>
            <h3>Ausgangslage klären</h3>
            <p>Innenbereich, Außenbereich oder Bebauungsplan unterscheiden.</p>
          </div>
        </li>
        <li>
          <span>02</span>
          <div>
            <h3>Grundstück prüfen</h3>
            <p>Lage, Zusammenhang, Erschließung und Schutzbelange sammeln.</p>
          </div>
        </li>
        <li>
          <span>03</span>
          <div>
            <h3>Vorhaben schärfen</h3>
            <p>Wohnraumnutzen und städtebauliche Einordnung nachvollziehbar machen.</p>
          </div>
        </li>
        <li>
          <span>04</span>
          <div>
            <h3>Gemeinde ansprechen</h3>
            <p>Mit geordneten Unterlagen eine erste Einschätzung einholen.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  {featuredPost && (
    <section class="magazine">
      <div class="container">
        <header class="section-head section-head--magazine">
          <div>
            <p class="eyebrow">Aktuelle Einordnungen</p>
            <h2>Aus dem Magazin</h2>
          </div>
          <a href="/blog/" class="section-link">
            Alle Beiträge
            <svg aria-hidden="true" viewBox="0 0 18 18">
              <path d="M3 9h11M9.5 3.5 15 9l-5.5 5.5" />
            </svg>
          </a>
        </header>

        <div class="magazine__grid">
          <article class="lead-story">
            <figure class="lead-story__visual">
              {featuredVisual && (
                <img
                  src={featuredVisual.src}
                  srcset={featuredVisual.srcSet}
                  sizes="(max-width: 980px) 100vw, 54vw"
                  alt={featuredVisual.alt}
                  width={featuredVisual.width}
                  height={featuredVisual.height}
                  loading="lazy"
                  decoding="async"
                />
              )}
              <span>{categoryLabels[featuredPost.data.category] || featuredPost.data.category}</span>
              {featuredVisual && <figcaption>{featuredVisual.caption}</figcaption>}
            </figure>
            <div class="lead-story__body">
              <div class="story-meta">
                <span>{categoryLabels[featuredPost.data.category] || featuredPost.data.category}</span>
                <time datetime={featuredPost.data.pubDate.toISOString()}>
                  {dateFormatter.format(featuredPost.data.pubDate)}
                </time>
              </div>
              <h3>
                <a href={`/blog/${featuredPost.id}/`}>{featuredPost.data.title}</a>
              </h3>
              <p>{featuredPost.data.description}</p>
              <a href={`/blog/${featuredPost.id}/`} class="story-link">Beitrag lesen</a>
            </div>
          </article>

          <div class="story-list">
            {latestPosts.map((post) => (
              <article class="story-list__item">
                <div class="story-list__folio" aria-hidden="true">
                  {String(sortedPosts.indexOf(post) + 1).padStart(2, '0')}
                </div>
                <div>
                  <div class="story-meta">
                    <span>{categoryLabels[post.data.category] || post.data.category}</span>
                    <time datetime={post.data.pubDate.toISOString()}>
                      {dateFormatter.format(post.data.pubDate)}
                    </time>
                  </div>
                  <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
                  <p>{post.data.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="check-teaser">
    <div class="container check-teaser__grid">
      <div class="check-teaser__content">
        <p class="eyebrow">Standortprüfung in Vorbereitung</p>
        <h2>Passt Ihr Grundstück grundsätzlich ins Bild?</h2>
        <p>
          Die geplante Grundstücksprüfung führt Sie durch Lage, Abstand,
          Erschließung und Schutzbelange. Bis die Kartendaten angebunden sind,
          erhalten Sie bereits eine strukturierte Prüfliste.
        </p>
        <a href="/check/" class="button button--primary">
          Prüfung ansehen
          <svg aria-hidden="true" viewBox="0 0 18 18">
            <path d="M3 9h11M9.5 3.5 15 9l-5.5 5.5" />
          </svg>
        </a>
      </div>
      <div class="check-teaser__panel">
        <div class="check-teaser__map" aria-hidden="true">
          <i></i><i></i><i></i>
          <span class="map-marker"></span>
          <span class="map-radius"></span>
        </div>
        <ol>
          <li class="is-current"><span>1</span>Lage bestimmen</li>
          <li><span>2</span>Räumlichen Zusammenhang prüfen</li>
          <li><span>3</span>Fachbelange einordnen</li>
          <li><span>4</span>Ergebnis zusammenfassen</li>
        </ol>
      </div>
    </div>
  </section>

  <aside class="legal-note">
    <div class="container legal-note__inner">
      <span class="legal-note__icon" aria-hidden="true">§</span>
      <p>
        <strong>Wichtige Einordnung:</strong>
        Diese Website bietet allgemeine Informationen und keine Rechtsberatung.
        Für eine verbindliche Einschätzung wenden Sie sich an Ihre Gemeinde,
        die zuständige Bauaufsicht oder einen Fachanwalt für Baurecht.
      </p>
    </div>
  </aside>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: clamp(3.5rem, 8vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(7, 59, 92, 0.035) 1px, transparent 1px),
      linear-gradient(rgba(7, 59, 92, 0.035) 1px, transparent 1px),
      var(--paper);
    background-size: 36px 36px;
  }

  .hero::before {
    content: "";
    position: absolute;
    width: min(40vw, 560px);
    aspect-ratio: 1;
    top: -28%;
    right: -8%;
    border: 1px solid rgba(7, 59, 92, 0.12);
    border-radius: 50%;
    box-shadow:
      0 0 0 70px rgba(7, 59, 92, 0.025),
      0 0 0 140px rgba(7, 59, 92, 0.02);
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(420px, 0.98fr);
    gap: clamp(2.5rem, 6vw, 6rem);
    align-items: center;
  }

  .hero__content {
    animation: hero-enter 620ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--brick-600);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eyebrow--light {
    color: #f0a28f;
  }

  .hero h1 {
    max-width: 680px;
  }

  .hero h1 span {
    color: var(--blue-800);
    text-decoration: underline;
    text-decoration-color: var(--brick-500);
    text-decoration-thickness: 0.11em;
    text-underline-offset: 0.09em;
  }

  .hero__lead {
    max-width: 650px;
    margin: 1.6rem 0 0;
    color: var(--ink-600);
    font-size: clamp(1.05rem, 2vw, 1.26rem);
    line-height: 1.62;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .button {
    min-height: 50px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    padding: 0.8rem 1.15rem;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 800;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .button svg,
  .section-link svg,
  .topic-card__link svg {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
  }

  .button--primary {
    color: var(--white);
    background: var(--brick-600);
  }

  .button--primary:hover {
    color: var(--white);
    background: var(--blue-900);
    transform: translateY(-2px);
  }

  .button--secondary {
    color: var(--blue-900);
    background: transparent;
    border-color: var(--line-dark);
  }

  .button--secondary:hover {
    color: var(--blue-900);
    background: var(--white);
    border-color: var(--blue-900);
    transform: translateY(-2px);
  }

  .hero__assurances {
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.2rem;
    list-style: none;
    color: var(--ink-600);
    font-size: 0.84rem;
    font-weight: 700;
  }

  .hero__assurances li {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .hero__assurances svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: var(--land-600);
    stroke-width: 2.2;
  }

  .parcel-plan {
    position: relative;
    margin: 0;
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--line-dark);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    animation: plan-enter 720ms 100ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .parcel-plan::after {
    content: "";
    position: absolute;
    inset: 0;
    border: 5px solid var(--white);
    border-radius: inherit;
    pointer-events: none;
  }

  .parcel-plan__head,
  .parcel-plan figcaption {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    color: var(--ink-600);
    background: var(--white);
    font-family: var(--font-utility);
    font-size: var(--type-small);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .parcel-plan__head {
    border-bottom: 1px solid var(--line);
  }

  .parcel-plan__drawing {
    width: 100%;
    height: auto;
  }

  .parcel-plan figcaption {
    flex-wrap: wrap;
    justify-content: flex-start;
    border-top: 1px solid var(--line);
  }

  .parcel-plan figcaption > span:last-child {
    margin-left: auto;
  }

  .parcel-plan__legend {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .legend-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
  }

  .legend-dot--brick {
    background: var(--brick-600);
  }

  .legend-dot--land {
    background: var(--land-600);
  }

  .facts {
    color: var(--white);
    background: var(--blue-900);
  }

  .facts__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .facts article {
    min-width: 0;
    padding: 1.55rem clamp(1rem, 3vw, 2rem);
    border-left: 1px solid rgba(255, 255, 255, 0.17);
  }

  .facts article:last-child {
    border-right: 1px solid rgba(255, 255, 255, 0.17);
  }

  .facts__label {
    display: block;
    margin-bottom: 0.35rem;
    color: #93bbc9;
    font-size: var(--type-small);
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .facts strong {
    display: block;
    margin-bottom: 0.2rem;
    color: var(--white);
    font-size: 1.02rem;
  }

  .facts a {
    color: rgba(255, 255, 255, 0.67);
    font-size: 0.82rem;
    text-underline-offset: 0.22em;
  }

  .facts a:hover {
    color: var(--white);
  }

  .topics,
  .magazine {
    padding: clamp(4.5rem, 9vw, 8rem) 0;
  }

  .section-head {
