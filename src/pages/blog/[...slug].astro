---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getBlogVisual } from '../../lib/blogVisuals';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const visual = getBlogVisual(entry.id, entry.data.category);
const relatedPosts = (await getCollection('blog'))
  .filter((candidate) => candidate.id !== entry.id)
  .map((candidate) => ({
    id: candidate.id,
    title: candidate.data.title,
    description: candidate.data.description,
    score:
      (candidate.data.parentHub === entry.data.parentHub ? 5 : 0)
      + (candidate.data.topic === entry.data.topic ? 4 : 0)
      + (candidate.data.searchTask !== entry.data.searchTask ? 2 : 0)
      + (candidate.data.intent === entry.data.intent ? 1 : 0)
      + candidate.data.tags.filter((tag) => entry.data.tags.includes(tag)).length,
  }))
  .sort((a, b) => b.score - a.score || a.title.localeCompare(b.title, 'de'))
  .slice(0, 2);
const wordCount = entry.body
  .replace(/---[\s\S]*?---/, '')
  .replace(/<[^>]+>|[#*_`>[\]()!-]/g, ' ')
  .split(/\s+/)
  .filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 180));
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  quickAnswer={entry.data.quickAnswer}
  keyPoints={entry.data.keyPoints}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  category={entry.data.category}
  contentType={entry.data.contentType}
  intent={entry.data.intent}
  tags={entry.data.tags}
  sources={entry.data.sources}
  headings={headings}
  readingMinutes={readingMinutes}
  visual={visual}
  enhanced={true}
  relatedPosts={relatedPosts}
>
  <Content />
</ArticleLayout>
