---
import BaseLayout from './BaseLayout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import SourcesBox from '../components/SourcesBox.astro';
import type { BlogVisual } from '../lib/blogVisuals';
import { audienceLabels, type Audience } from '../lib/audiences';
import { SITE } from '../lib/site';

interface ArticleHeading {
  depth: number;
  slug: string;
  text: string;
}

export interface Props {
  title: string;
  description: string;
  quickAnswer?: string;
  keyPoints?: string[];
  pubDate?: Date;
  updatedDate?: Date;
  category?: string;
  contentType?: 'ratgeber' | 'nachricht' | 'projekt' | 'entscheidung';
  intent?: Audience;
  tags?: string[];
  sources?: Array<{
    label: string;
    url: string;
    type?: 'primary' | 'secondary';
  }>;
  headings?: ArticleHeading[];
  readingMinutes?: number;
  visual?: BlogVisual;
  enhanced?: boolean;
  relatedPosts?: Array<{
    id: string;
    title: string;
    description: string;
  }>;
}

const {
  title,
  description,
  quickAnswer,
  keyPoints = [],
  pubDate,
  updatedDate,
  category,
  contentType = 'ratgeber',
  intent = 'owner',
  tags,
  sources = [],
  headings = [],
  readingMinutes = 1,
  visual,
  enhanced = false,
  relatedPosts = [],
} = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('de-DE', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const categoryLabels: Record<string, string> = {
  grundlagen: 'Grundlagen',
  '100m': '100-m-Leitplanke',
  aussenbereich: 'Außenbereich',
  ablauf: 'Verfahren',
  faq: 'Praxisfragen',
};

const tableOfContents = headings.filter((heading) => heading.depth === 2).slice(0, 9);
const absoluteUrl = (path: string) =>
  Astro.site ? new URL(path, Astro.site).toString() : path;
const structuredData = pubDate
  ? {
      '@context': 'https://schema.org',
      '@type': contentType === 'nachricht'
        ? 'NewsArticle'
        : contentType === 'ratgeber'
          ? 'BlogPosting'
          : 'Article',
      headline: title,
      description,
      mainEntityOfPage: absoluteUrl(Astro.url.pathname),
      datePublished: pubDate.toISOString(),
      dateModified: (updatedDate ?? pubDate).toISOString(),
      image: (visual?.schemaImages ?? (visual ? [visual.src] : [])).map(absoluteUrl),
      publisher: {
        '@type': 'Person',
        name: SITE.publisher.name,
        url: absoluteUrl(SITE.publisher.page),
      },
      isPartOf: {
        '@type': 'Blog',
        name: `${SITE.name} – Magazin`,
        url: absoluteUrl('/blog/'),
      },
      inLanguage: 'de-DE',
    }
  : undefined;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={visual?.src}
  ogImageAlt={visual?.alt}
  ogType={pubDate ? 'article' : 'website'}
  structuredData={structuredData}
>
  {enhanced && (
    <div class="reading-progress" aria-hidden="true">
      <span data-reading-progress></span>
    </div>
  )}

  <article
    class:list={['article', { 'is-enhanced': enhanced }]}
    data-reading-article
    data-content-type={contentType}
  >
    <div class="container">
      <nav class="breadcrumb" aria-label="Brotkrümelnavigation">
        <a href="/">Start</a>
        <svg aria-hidden="true" viewBox="0 0 16 16">
          <path d="m6 3 5 5-5 5" />
        </svg>
        {pubDate ? <a href="/blog/">Magazin</a> : <span>Ratgeber</span>}
      </nav>

      <header class:list={['article-header', { 'is-enhanced': enhanced && visual }]}>
        <div class="article-header__intro">
          {category && (
            <p class="article-header__category">
              {categoryLabels[category] || category} · {audienceLabels[intent]}
            </p>
          )}
          <h1>{title}</h1>
          <p class="article-header__description">{description}</p>
          <p class="article-header__publisher">
            Herausgegeben von <a href={SITE.publisher.page}>{SITE.publisher.name}</a>
            <span aria-hidden="true">·</span>
            <a href={SITE.publisher.page}>Quellen und Prüfmethode</a>
          </p>

          {(pubDate || (tags && tags.length > 0)) && (
            <div class="article-header__details">
              {pubDate && (
                <div class="article-dates">
                  <span>Veröffentlicht</span>
                  <time datetime={pubDate.toISOString()}>
                    {dateFormatter.format(pubDate)}
                  </time>
                  {updatedDate && (
                    <>
                      <span>Aktualisiert</span>
                      <time datetime={updatedDate.toISOString()}>
                        {dateFormatter.format(updatedDate)}
                      </time>
                    </>
                  )}
                </div>
              )}

              {tags && tags.length > 0 && (
                <ul class="article-tags" aria-label="Schlagworte">
                  {tags.map((tag) => <li>{tag}</li>)}
                </ul>
              )}
            </div>
          )}
        </div>

        {enhanced && visual && (
          <figure class="article-header__visual">
            <img
              src={visual.src}
              srcset={visual.srcSet}
              sizes="(max-width: 820px) 100vw, 42vw"
              alt={visual.alt}
              width={visual.width}
              height={visual.height}
              fetchpriority="high"
              decoding="async"
            />
            <figcaption>{visual.caption}</figcaption>
          </figure>
        )}
      </header>

      <div class="article-grid">
        <div class="article-main">
          {enhanced && quickAnswer && keyPoints.length > 0 && (
            <section class="article-summary" aria-labelledby="article-summary-title">
              <div class="article-summary__answer">
                <p class="article-summary__label">Kurzantwort</p>
                <h2 id="article-summary-title">Das Wichtigste zuerst</h2>
                <p>{quickAnswer}</p>
              </div>
              <div class="article-summary__points">
                <p>Darauf kommt es an</p>
                <ul>
                  {keyPoints.map((point) => <li>{point}</li>)}
                </ul>
              </div>
            </section>
          )}

          {enhanced && tableOfContents.length > 0 && (
            <section class="article-overview" aria-labelledby="article-overview-title">
              <div class="article-overview__intro">
                <p class="article-overview__label">Schnelle Orientierung</p>
                <h2 id="article-overview-title">In diesem Beitrag</h2>
                <p>{readingMinutes} Minuten Lesezeit · direkt zum passenden Abschnitt springen</p>
              </div>

              <nav class="article-overview__nav" aria-label="Inhaltsübersicht">
                <ol>
                  {tableOfContents.map((heading) => (
                    <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
                  ))}
                </ol>
              </nav>

              <div class="article-overview__actions">
                <a class="article-overview__primary" href="/grundstueckspotenzial-brandenburg/">Nächsten Schritt wählen</a>
                <button type="button" data-share-article>Beitrag teilen</button>
                <input
                  class="article-overview__share-field"
                  data-share-field
                  aria-label="Beitragsadresse"
                  value={absoluteUrl(Astro.url.pathname)}
                  readonly
                  hidden
                />
                <span class="article-overview__status" data-share-status aria-live="polite"></span>
              </div>
            </section>
          )}

          <div class="article-content">
            <slot />
          </div>

          <SourcesBox sources={sources} />
          <Disclaimer />

          {relatedPosts.length > 0 && (
            <section class="related-posts" aria-labelledby="related-posts-title">
              <p class="related-posts__label">Passende Vertiefungen</p>
              <h2 id="related-posts-title">Damit können Sie weiterarbeiten</h2>
              <div>
                {relatedPosts.map((post) => (
                  <a href={`/blog/${post.id}/`}>
                    <strong>{post.title}</strong>
                    <span>{post.description}</span>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>

        <aside class="article-rail" aria-label="Weiterführende Themen">
          <div class="article-rail__box">
            <p class="article-rail__label">Weiter einordnen</p>
            <a href="/246e-baugb-brandenburg/">
              <span>Grundlagen</span>
              <svg aria-hidden="true" viewBox="0 0 16 16">
                <path d="M3 8h10M9 4l4 4-4 4" />
              </svg>
            </a>
            <a href="/100m-regel-raeumlicher-zusammenhang/">
              <span>100-m-Leitplanke</span>
              <svg aria-hidden="true" viewBox="0 0 16 16">
                <path d="M3 8h10M9 4l4 4-4 4" />
              </svg>
            </a>
            <a href="/aussenbereich-brandenburg-246e/">
              <span>Außenbereich</span>
              <svg aria-hidden="true" viewBox="0 0 16 16">
                <path d="M3 8h10M9 4l4 4-4 4" />
              </svg>
            </a>
            <a href="/zustimmung-gemeinde-246e/">
              <span>Gemeinde-Zustimmung</span>
              <svg aria-hidden="true" viewBox="0 0 16 16">
                <path d="M3 8h10M9 4l4 4-4 4" />
              </svg>
            </a>
            <a href="/grundstueckspotenzial-brandenburg/">
              <span>Nächster Schritt</span>
              <svg aria-hidden="true" viewBox="0 0 16 16">
                <path d="M3 8h10M9 4l4 4-4 4" />
              </svg>
            </a>
            <a href={SITE.publisher.page}>
              <span>Redaktion und Methodik</span>
              <svg aria-hidden="true" viewBox="0 0 16 16">
                <path d="M3 8h10M9 4l4 4-4 4" />
              </svg>
            </a>
          </div>

          <div class="article-rail__note">
            <span aria-hidden="true">§</span>
            <p>
              Rechtsverbindliche Auskünfte erhalten Sie bei Gemeinde,
              Bauaufsicht oder fachanwaltlicher Beratung.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding: clamp(2.5rem, 6vw, 5.5rem) 0 clamp(4rem, 9vw, 8rem);
    background:
      linear-gradient(90deg, rgba(7, 59, 92, 0.025) 1px, transparent 1px),
      var(--paper);
    background-size: 42px 42px;
  }

  .reading-progress {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 1100;
    height: 4px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.7);
    pointer-events: none;
  }

  .reading-progress span {
    width: 100%;
    height: 100%;
    display: block;
    background: var(--brick-500);
    transform: scaleX(0);
    transform-origin: left center;
    will-change: transform;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: clamp(2rem, 5vw, 4rem);
    color: var(--ink-600);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .breadcrumb a {
    color: var(--blue-800);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--brick-600);
  }

  .breadcrumb svg {
    width: 0.8rem;
    height: 0.8rem;
    fill: none;
    stroke: var(--line-dark);
    stroke-width: 1.8;
  }

  .article-header {
    max-width: 900px;
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
    border-bottom: 1px solid var(--line-dark);
  }

  .article-header.is-enhanced {
    max-width: none;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.8fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .article-header__intro {
    min-width: 0;
  }

  .article-header__visual {
    min-width: 0;
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    margin: 0;
    background: var(--blue-050);
    border: 1px solid var(--line-dark);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  .article-header__visual img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .article-header__visual figcaption {
    position: absolute;
    right: 0.75rem;
    bottom: 0.75rem;
    left: 0.75rem;
    padding: 0.5rem 0.65rem;
    color: var(--white);
    background: rgba(16, 38, 49, 0.84);
    border-radius: var(--radius-sm);
    font-size: 0.67rem;
    font-weight: 800;
    letter-spacing: 0.03em;
  }

  .article-header__category {
    margin: 0 0 1rem;
    color: var(--brick-600);
    font-size: 0.73rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .article-header h1 {
    max-width: 22ch;
    font-size: var(--editorial-title-size);
    line-height: var(--editorial-title-leading);
    text-wrap: balance;
  }

  .article-header__description {
    max-width: 62ch;
    margin: 1.35rem 0 0;
    color: var(--ink-600);
    font-size: clamp(1.125rem, 1vw + 0.9rem, 1.25rem);
    line-height: 1.6;
  }

  .article-header__publisher {
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    color: var(--ink-600);
    font-size: 0.76rem;
  }

  .article-header__publisher a {
    color: var(--blue-800);
    font-weight: 800;
    text-underline-offset: 0.18em;
  }

  .article-header__details {
    margin-top: 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .article-dates {
    display: grid;
    grid-template-columns: auto auto;
    gap: 0.2rem 0.7rem;
    font-size: 0.74rem;
  }

  .article-dates span {
    color: var(--ink-600);
  }

  .article-dates time {
    color: var(--ink-950);
    font-variant-numeric: tabular-nums;
    font-weight: 800;
  }

  .article-tags {
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.4rem;
    list-style: none;
  }

  .article-tags li {
    margin: 0;
    padding: 0.35rem 0.55rem;
    color: var(--ink-600);
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 700px) minmax(220px, 1fr);
    gap: clamp(3rem, 8vw, 7rem);
    align-items: start;
    padding-top: clamp(2.5rem, 6vw, 5rem);
  }

  .article-main {
    min-width: 0;
  }

  .article-summary {
    margin-bottom: clamp(1.5rem, 4vw, 2.25rem);
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(230px, 0.88fr);
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--line-dark);
    border-left: 5px solid var(--brick-500);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  .article-summary__answer {
    padding: clamp(1.4rem, 4vw, 2rem);
  }

  .article-summary__label,
  .article-summary__points > p {
    margin: 0 0 0.5rem;
    color: var(--brick-600);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .article-summary__answer h2 {
    margin: 0;
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    line-height: 1.15;
    text-wrap: balance;
  }

  .article-summary__answer > p:last-child {
    margin: 0.85rem 0 0;
    color: var(--ink-800);
    font-size: 1rem;
    line-height: 1.65;
  }

  .article-summary__points {
    padding: clamp(1.4rem, 4vw, 2rem);
    background: var(--blue-050);
    border-left: 1px solid var(--line);
  }

  .article-summary__points > p {
    color: var(--blue-800);
  }

  .article-summary__points ul {
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    list-style: none;
  }

  .article-summary__points li {
    margin: 0;
    padding-left: 1.35rem;
    position: relative;
    color: var(--ink-800);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .article-summary__points li::before {
    content: "";
    width: 0.5rem;
    height: 0.5rem;
    position: absolute;
    top: 0.38rem;
    left: 0;
    background: var(--brick-500);
    border-radius: 50%;
  }

  .article-overview {
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
    overflow: hidden;
    background: var(--white);
    border: 1px solid var(--line);
    border-top: 4px solid var(--brick-500);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  .article-overview__intro {
    padding: clamp(1.3rem, 4vw, 2rem);
    border-bottom: 1px solid var(--line);
  }

  .article-overview__label {
    margin: 0 0 0.45rem;
    color: var(--brick-600);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .article-overview__intro h2 {
    margin: 0;
    font-size: clamp(1.55rem, 3vw, 2.15rem);
  }

  .article-overview__intro > p:last-child {
    margin: 0.55rem 0 0;
    color: var(--ink-600);
    font-size: 0.84rem;
  }

  .article-overview__nav {
    padding: 0.65rem clamp(1.3rem, 4vw, 2rem);
  }

  .article-overview__nav ol {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: overview;
  }

  .article-overview__nav li {
    counter-increment: overview;
    border-bottom: 1px solid var(--line);
  }

  .article-overview__nav li:last-child {
    border-bottom: 0;
  }

  .article-overview__nav a {
    min-height: 48px;
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.65rem;
    align-items: center;
    padding: 0.7rem 0;
    color: var(--ink-800);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 800;
  }

  .article-overview__nav a::before {
    content: counter(overview, decimal-leading-zero);
    color: var(--brick-600);
    font-family: ui-monospace, "SFMono-Regular", Consolas, monospace;
    font-size: 0.65rem;
  }

  .article-overview__nav a:hover {
    color: var(--brick-600);
  }

  .article-overview__actions {
    min-height: 68px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem clamp(1.3rem, 4vw, 2rem);
    background: var(--blue-050);
  }

  .article-overview__actions a,
  .article-overview__actions button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 0.9rem;
    color: var(--blue-900);
    background: var(--white);
    border: 1px solid var(--line-dark);
    border-radius: var(--radius-sm);
    font: inherit;
    font-size: 0.76rem;
    font-weight: 900;
    text-decoration: none;
    cursor: pointer;
    touch-action: manipulation;
  }

  .article-overview__actions .article-overview__primary {
    color: var(--white);
    background: var(--blue-900);
    border-color: var(--blue-900);
  }

  .article-overview__actions a:hover,
  .article-overview__actions button:hover {
    color: var(--white);
    background: var(--brick-600);
    border-color: var(--brick-600);
  }

  .article-overview__actions a:focus-visible,
  .article-overview__actions button:focus-visible {
    outline: 3px solid var(--brick-500);
    outline-offset: 3px;
  }

  .article-overview__status {
    min-height: 1.3em;
    color: var(--ink-600);
    font-size: 0.72rem;
  }

  .article-overview__share-field {
    min-width: min(100%, 18rem);
    min-height: 44px;
    padding: 0.65rem 0.75rem;
    color: var(--ink-800);
    background: var(--white);
    border: 1px solid var(--line-dark);
    border-radius: var(--radius-sm);
    font: inherit;
    font-size: 0.75rem;
  }

  .article-overview__share-field:focus-visible {
    outline: 3px solid var(--brick-500);
    outline-offset: 2px;
  }

  .is-enhanced .article-content :global(h2) {
    scroll-margin-top: 8rem;
  }

  .article-content {
    max-width: var(--editorial-measure);
    color: var(--ink-800);
    font-size: var(--editorial-body-size);
    line-height: var(--editorial-body-leading);
  }

  .article-content :global(h2) {
    margin: var(--editorial-h2-space-before) 0 var(--editorial-h2-space-after);
    padding-top: 0.3rem;
    color: var(--ink-950);
    font-size: var(--editorial-h2-size);
    line-height: var(--editorial-h2-leading);
    text-wrap: balance;
  }

  .article-content :global(h2)::before {
    content: "";
    width: 42px;
    height: 3px;
    display: block;
    margin-bottom: 1rem;
    background: var(--brick-500);
  }

  .article-content :global(h3) {
    margin: var(--editorial-h3-space-before) 0 var(--editorial-h3-space-after);
    color: var(--ink-950);
    font-size: var(--editorial-h3-size);
    line-height: var(--editorial-h3-leading);
    text-wrap: balance;
  }

  .article-content :global(p),
  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: var(--editorial-paragraph-space);
    text-wrap: pretty;
  }

  .article-content :global(li) {
    margin-bottom: var(--editorial-list-item-space);
    padding-left: 0.2rem;
  }

  .article-content :global(a) {
    color: var(--blue-800);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .article-content :global(a:hover) {
    color: var(--brick-600);
  }

  .article-content :global(strong) {
    color: var(--ink-950);
    font-weight: 800;
  }

  .article-content :global(blockquote) {
    margin: 2rem 0;
    padding: 1.35rem 1.5rem;
    color: var(--blue-900);
    background: var(--blue-050);
    border-left: 4px solid var(--brick-500);
    font-size: 1.04em;
  }

  .article-content :global(code) {
    padding: 0.16rem 0.35rem;
    background: var(--blue-050);
    border-radius: var(--radius-sm);
    font-family: ui-monospace, "SFMono-Regular", Consolas, monospace;
    font-size: 0.9em;
  }

  .article-content :global(pre) {
