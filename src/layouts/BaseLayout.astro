---
import SEO from '../components/SEO.astro';
import { SITE } from '../lib/site';
import '../styles/editorial.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  robots?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  frontmatter?: {
    title?: string;
    description?: string;
    canonical?: string;
  };
}

const frontmatter = Astro.props.frontmatter ?? {};
const {
  title = frontmatter.title,
  description = frontmatter.description,
  canonical = frontmatter.canonical,
  ogImage,
  ogImageAlt,
  ogType,
  robots,
  structuredData,
} = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/246e-baugb-brandenburg/', label: 'Grundlagen' },
  { href: '/100m-regel-raeumlicher-zusammenhang/', label: '100-m-Leitplanke' },
  { href: '/aussenbereich-brandenburg-246e/', label: 'Außenbereich' },
  { href: '/zustimmung-gemeinde-246e/', label: 'Gemeinde' },
  { href: '/blog/', label: 'Magazin' },
];

const isActive = (href: string) => currentPath.startsWith(href);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#073b5c" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogType={ogType}
      robots={robots}
      structuredData={structuredData}
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>

    <div class="utility-bar">
      <div class="container utility-bar__inner">
        <span>Praxisleitfaden für Eigentümer und Grundstücksmakler</span>
        <a class="utility-bar__region" href={SITE.publisher.page}>Brandenburg · Quellen und Prüfmethode</a>
      </div>
    </div>

    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="brand" aria-label="§246e BauGB Brandenburg – Startseite">
          <span class="brand__mark" translate="no">§246e</span>
          <span class="brand__descriptor">BauGB<br />Brandenburg</span>
        </a>

        <nav class="desktop-nav" aria-label="Hauptnavigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={{ 'is-active': isActive(item.href) }}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
          <a href="/grundstueckspotenzial-brandenburg/" class="nav-cta">
            Grundstück einordnen
            <svg aria-hidden="true" viewBox="0 0 16 16">
              <path d="M3 8h9M8.5 3.5 13 8l-4.5 4.5" />
            </svg>
          </a>
        </nav>

        <details class="mobile-menu">
          <summary>
            <span>Menü</span>
            <svg aria-hidden="true" viewBox="0 0 20 20">
              <path d="M3 5h14M3 10h14M3 15h14" />
            </svg>
          </summary>
          <nav aria-label="Mobile Navigation">
            {navItems.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
            <a href="/grundstueckspotenzial-brandenburg/" class="mobile-menu__cta">Grundstück einordnen</a>
          </nav>
        </details>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="site-footer__grid">
          <div class="site-footer__intro">
            <a href="/" class="brand brand--footer" aria-label="§246e BauGB Brandenburg – Startseite">
              <span class="brand__mark" translate="no">§246e</span>
              <span class="brand__descriptor">BauGB<br />Brandenburg</span>
            </a>
            <p>Verständliche Orientierung zu Grundstück, Verfahren und befristetem Baurecht.</p>
          </div>
          <div class="footer-column">
            <h2>Themen</h2>
            <a href="/246e-baugb-brandenburg/">Grundlagen</a>
            <a href="/100m-regel-raeumlicher-zusammenhang/">100-m-Leitplanke</a>
            <a href="/aussenbereich-brandenburg-246e/">Außenbereich</a>
            <a href="/zustimmung-gemeinde-246e/">Gemeinde-Zustimmung</a>
          </div>
          <div class="footer-column">
            <h2>Weiterlesen</h2>
            <a href="/blog/">Magazin</a>
            <a href="/grundstueckspotenzial-brandenburg/">Grundstück einordnen</a>
            <a href="/check/">Kartenwerkzeug in Vorbereitung</a>
            <a href="/rss.xml">RSS-Feed</a>
          </div>
          <div class="footer-column">
            <h2>Rechtliches</h2>
            <a href={SITE.publisher.page}>Herausgeber: {SITE.publisher.name}</a>
            <a href={SITE.publisher.page}>Redaktion und Methodik</a>
            <a href="/impressum/">Impressum</a>
            <a href="/datenschutz/">Datenschutz</a>
            <p>Keine Rechtsberatung</p>
          </div>
        </div>
        <div class="site-footer__bottom">
          <p>&copy; {new Date().getFullYear()} §246e BauGB Brandenburg</p>
          <p>Für Eigentümer, Bauwillige und Grundstücksmakler in Brandenburg</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --ink-950: #102631;
    --ink-800: #1d3a48;
    --ink-600: #4f6873;
    --blue-900: #073b5c;
    --blue-800: #0a4a70;
    --blue-100: #dcecf1;
    --blue-050: #edf5f7;
    --brick-600: #be4f37;
    --brick-500: #d45d42;
    --brick-100: #f5ddd7;
    --land-600: #66806d;
    --paper: #f4f7f8;
    --white: #ffffff;
    --line: #cbd8dd;
    --line-dark: #9bb0ba;
    --warning-bg: #fff4d6;
    --warning-line: #d79a22;
    --shadow-soft: 0 18px 45px rgba(16, 38, 49, 0.08);
    --max-width: 1180px;
    --text-width: 740px;
    --spacing: clamp(1rem, 3vw, 1.75rem);
    --radius-sm: 4px;
    --radius-md: 12px;
    --radius-lg: 22px;

    /* Legacy aliases used by existing article styles. */
    --color-primary: var(--blue-800);
    --color-text: var(--ink-950);
    --color-text-light: var(--ink-600);
    --color-border: var(--line);
    --color-bg: var(--white);
    --color-bg-alt: var(--blue-050);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 7rem;
    font-family: "Avenir Next", Avenir, "Segoe UI", system-ui, sans-serif;
    line-height: 1.55;
    color: var(--ink-950);
    background: var(--paper);
    -webkit-text-size-adjust: 100%;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    background: var(--paper);
    text-rendering: optimizeLegibility;
  }

  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--spacing);
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 1000;
    transform: translateY(-160%);
    padding: 0.7rem 1rem;
    background: var(--white);
    color: var(--blue-900);
    border: 2px solid var(--brick-500);
    text-decoration: none;
    font-weight: 700;
    transition: transform 160ms ease;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .utility-bar {
    background: var(--blue-900);
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }

  .utility-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 34px;
    gap: 1.5rem;
  }

  .utility-bar__region {
    color: inherit;
    text-decoration-color: rgba(255, 255, 255, 0.35);
    text-underline-offset: 0.18em;
  }

  .utility-bar__region:hover {
    color: var(--white);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(14px);
  }

  .site-header__inner {
    min-height: 86px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    color: var(--blue-900);
    text-decoration: none;
    flex: 0 0 auto;
  }

  .brand__mark {
    font-family: "Avenir Next Condensed", "Arial Narrow", sans-serif;
    font-size: 2rem;
    line-height: 0.9;
    font-weight: 900;
    letter-spacing: -0.055em;
  }

  .brand__descriptor {
    padding-left: 0.72rem;
    border-left: 1px solid var(--line-dark);
    color: var(--ink-600);
    font-size: 0.68rem;
    line-height: 1.16;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(0.7rem, 1.6vw, 1.35rem);
  }

  .desktop-nav a {
    position: relative;
    color: var(--ink-800);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
    transition: color 160ms ease;
  }

  .desktop-nav a:not(.nav-cta)::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -0.55rem;
    left: 0;
    height: 2px;
    background: var(--brick-500);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 160ms ease;
  }

  .desktop-nav a:hover,
  .desktop-nav a.is-active {
    color: var(--blue-900);
  }

  .desktop-nav a:hover::after,
  .desktop-nav a.is-active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .desktop-nav .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.72rem 0.9rem;
    color: var(--white);
    background: var(--brick-600);
    border-radius: var(--radius-sm);
    transition: background-color 160ms ease, transform 160ms ease;
  }

  .nav-cta svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.75;
  }

  .desktop-nav .nav-cta:hover {
    color: var(--white);
    background: var(--blue-900);
    transform: translateY(-1px);
  }

  .mobile-menu {
    display: none;
    position: relative;
  }

  .mobile-menu summary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    color: var(--blue-900);
    font-weight: 800;
    cursor: pointer;
    list-style: none;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu summary svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
  }

  .mobile-menu[open] nav {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    width: min(82vw, 320px);
    padding: 0.75rem;
    display: grid;
    gap: 0.25rem;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  .mobile-menu nav a {
    min-height: 44px;
    display: flex;
    align-items: center;
    padding: 0.7rem 0.8rem;
    border-radius: var(--radius-sm);
    color: var(--ink-800);
    text-decoration: none;
    font-weight: 700;
  }

  .mobile-menu nav a:hover,
  .mobile-menu nav a[aria-current="page"] {
    color: var(--blue-900);
    background: var(--blue-050);
  }

  .mobile-menu nav .mobile-menu__cta {
    margin-top: 0.35rem;
    color: var(--white);
    background: var(--brick-600);
  }

  main {
    flex: 1;
  }

  main > .container {
    padding-top: clamp(2.75rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 8vw, 6rem);
  }

  .site-footer {
    margin-top: auto;
    padding: clamp(3rem, 7vw, 5rem) 0 1.5rem;
    background: var(--blue-900);
    color: rgba(255, 255, 255, 0.74);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: minmax(260px, 1.6fr) repeat(3, minmax(130px, 1fr));
    gap: clamp(2rem, 5vw, 4.5rem);
    padding-bottom: 3rem;
  }

  .brand--footer {
    color: var(--white);
  }

  .brand--footer .brand__descriptor {
    color: rgba(255, 255, 255, 0.62);
    border-color: rgba(255, 255, 255, 0.32);
  }

  .site-footer__intro p {
    max-width: 310px;
    margin-top: 1.35rem;
    font-size: 0.92rem;
  }

  .footer-column h2 {
    margin: 0 0 1rem;
    color: var(--white);
    font-size: 0.73rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-column a,
  .footer-column p {
    display: block;
    width: fit-content;
    margin-bottom: 0.65rem;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    font-size: 0.86rem;
    transition: color 160ms ease;
  }

  .footer-column a:hover {
    color: var(--white);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 0.75rem;
    letter-spacing: 0.025em;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "Avenir Next Condensed", "Arial Narrow", "Segoe UI", sans-serif;
    line-height: 1.08;
    color: var(--ink-950);
    text-wrap: balance;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 5.3rem);
    letter-spacing: -0.055em;
  }

  h2 {
    font-size: clamp(1.9rem, 4vw, 3.15rem);
    letter-spacing: -0.035em;
  }

  h3 {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    letter-spacing: -0.025em;
  }

  h4 {
    font-size: 1.15rem;
  }

  p {
    margin-bottom: 1rem;
    text-wrap: pretty;
  }

  a {
    color: var(--blue-800);
  }

  a,
  button,
  summary {
    touch-action: manipulation;
    -webkit-tap-highlight-color: rgba(7, 59, 92, 0.12);
  }

  a:focus-visible,
  button:focus-visible,
  summary:focus-visible,
  input:focus-visible,
  textarea:focus-visible,
  select:focus-visible {
    outline: 3px solid var(--brick-500);
    outline-offset: 3px;
  }

  ul,
  ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  li {
    margin-bottom: 0.5rem;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  :where(h1, h2, h3, h4, h5, h6)[id] {
    scroll-margin-top: 8rem;
  }

  @media (max-width: 980px) {
    .desktop-nav {
      display: none;
    }

    .mobile-menu {
      display: block;
    }

    .site-footer__grid {
      grid-template-columns: 1.5fr repeat(2, 1fr);
    }

    .footer-column:last-child {
      grid-column: 2 / -1;
    }
  }

  @media (max-width: 640px) {
    .utility-bar__region {
      display: none;
    }

    .site-header__inner {
      min-height: 74px;
    }

    .brand__mark {
      font-size: 1.65rem;
    }

    .brand__descriptor {
      font-size: 0.6rem;
    }

    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
    }

    .site-footer__intro {
      grid-column: 1 / -1;
    }

    .footer-column:last-child {
      grid-column: auto;
    }

    .site-footer__bottom {
      display: grid;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
